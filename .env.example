# Application
PORT=3000
APP_HOST_PORT=3001
NODE_ENV=development
IP_ADDRESS="0.0.0.0"

# db config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=fintech_wallet
DB_HOST_PORT=5433

# db connection
DATABASE_URL="postgresql://postgres:password@localhost:5433/fintech_wallet?schema=public"
DB_POOL_MIN=20
DB_POOL_MAX=50

# Outbox Poller
OUTBOX_POLL_LIMIT=100
OUTBOX_POLL_CRON="*/2 * * * * *"

#redis
REDIS_HOST="localhost"
REDIS_PORT=6380
REDIS_HOST_PORT=6380

#jwt
JWT_SECRET="supersecretjwtkey_to_be_updated_in_prod_01234567890123456789012345678"
JWT_ISSUER="fintech_api"
